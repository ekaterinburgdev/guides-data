    {
      "id": 47,
      "type": "heading_1",
      "content": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Проблемы",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
