    {
      "id": "916c7f98-0143-495e-b90a-59df405cf96c",
      "type": "paragraph",
      "content": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Описание",
              "link": null
            },
            "annotations": {
              "bold": true,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
            },
            "plain_text": "Описание",
            "href": null
          },
          {
            "type": "text",
            "text": {
              "content": ": программа направлена на решение проблемы антиобщественнного поведения в парках за счет единовременного проведения многих небольших позитивных мероприятий (уличное искусство, концерты в обеденное время, танцы). Департамент муниципалитета действовал в партнерстве с НКО. В парках работают консьержи, отвечающие на вопросы горожан, помогают с установкой игрового оборудования, уборкой, поддерживают проведение мероприятий. Присутствие в парке человека в униформе помогает снизить преступность и антиобщественное поведение.",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
            },
            "plain_text": ": программа направлена на решение проблемы антиобщественнного поведения в парках за счет единовременного проведения многих небольших позитивных мероприятий (уличное искусство, концерты в обеденное время, танцы). Департамент муниципалитета действовал в партнерстве с НКО. В парках работают консьержи, отвечающие на вопросы горожан, помогают с установкой игрового оборудования, уборкой, поддерживают проведение мероприятий. Присутствие в парке человека в униформе помогает снизить преступность и антиобщественное поведение.",
            "href": null
