                "rich_text": [
                  {
                    "type": "text",
                    "text": {
                      "content": "Конструкция с водой, бьющей под напором вверх, и наземной чашей. Водные картины создаются обилием воды, разнообразными водными эффектами, подсветкой. Применяются для оживления пространства, а также являются центром архитектурно-планировочной композиции",
                      "link": null
                    },
                    "annotations": {
