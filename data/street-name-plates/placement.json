    {
      "id": "5e7661b2-9baf-47fa-961b-39331b0dd9dc",
      "type": "paragraph",
      "content": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Адресные таблички размещаются в диапазоне от 2,5 до 5 м от уровня земли.",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
            },
            "plain_text": "Адресные таблички размещаются в диапазоне от 2,5 до 5 м от уровня земли.",
            "href": null
          }
        ],
        "icon": null,
        "color": "default"
      },
      "children": []
    },
    {
      "id": "9524ab39-912a-41dd-9f2b-7fddc09517dc",
      "type": "paragraph",
      "content": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Адресные таблички размещаются с учётом расположения элементов фасада, уровня окон и проёмов фасада.",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
            },
            "plain_text": "Адресные таблички размещаются с учётом расположения элементов фасада, уровня окон и проёмов фасада.",
            "href": null
          }
        ],
        "icon": null,
        "color": "default"
      },
      "children": []
