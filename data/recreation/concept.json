      "content": {
        "rich_text": [
          {
            "type": "text",
            "text": {
              "content": "Долгосрочность и целостность",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
              "strikethrough": false,
              "underline": false,
              "code": false,
              "color": "default"
