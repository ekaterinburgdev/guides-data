            "href": null
          },
          {
            "type": "text",
            "text": {
              "content": " – озелененная территория общего пользования вдоль магистралей, набережных либо в зоне жилой или общественной застройки в виде полосы различной ширины, предназначенная для пешеходного транзитного движения и кратковременного отдыха.",
              "link": null
            },
            "annotations": {
              "bold": false,
              "italic": false,
